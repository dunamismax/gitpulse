---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout
  title="Sessions"
  page="sessions"
  activeNav="sessions"
  eyebrow="Focus Sessions"
  heading="Session rhythm"
  description="Sessions are built from activity windows separated by inactivity gaps."
>
  <div class="page-body" x-data="window.gitpulse.sessionsPage()" x-init="init()">
    <div class="notice" x-cloak x-show="loading">Loading sessions…</div>
    <div class="notice notice-error" x-cloak x-show="error" x-text="error"></div>

    <section class="grid three">
      <article class="stat-card"><span>Total Minutes</span><strong x-text="summary.total_minutes"></strong></article>
      <article class="stat-card"><span>Average Session</span><strong><span x-text="summary.average_length_minutes"></span> min</strong></article>
      <article class="stat-card"><span>Longest Session</span><strong><span x-text="summary.longest_session_minutes"></span> min</strong></article>
    </section>

    <section class="panel">
      <header class="panel-head"><h3>Recent Sessions</h3></header>
      <div class="session-list" x-show="summary.sessions.length">
        <template x-for="session in summary.sessions" :key="session.id">
          <div class="session-row session-row-wrap">
            <div>
              <strong><span x-text="session.active_minutes"></span> min</strong>
              <p><span x-text="formatTime(session.started_at)"></span> to <span x-text="formatTime(session.ended_at)"></span></p>
            </div>
            <span class="chip"><span x-text="session.total_changed_lines"></span> changed lines</span>
          </div>
        </template>
      </div>
      <p class="muted" x-show="!summary.sessions.length">No sessions recorded yet. Start coding to generate sessions.</p>
    </section>
  </div>
</AppLayout>
