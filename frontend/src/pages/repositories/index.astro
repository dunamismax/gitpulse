---
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout
  title="Repositories"
  page="repositories"
  activeNav="repositories"
  eyebrow="Tracked Targets"
  heading="Repositories"
  description="Add a single repo or a parent folder. Nested repos are discovered and tracked individually."
>
  <div class="page-body" x-data="window.gitpulse.repositoriesPage()" x-init="init()">
    <div class="notice" x-cloak x-show="loading">Loading repositories…</div>
    <div class="notice notice-success" x-cloak x-show="message" x-text="message"></div>
    <div class="notice notice-error" x-cloak x-show="error" x-text="error"></div>

    <section class="panel panel-tight">
      <form class="inline-form" @submit.prevent="addTarget()">
        <input type="text" name="path" placeholder="/Users/you/code" required x-model="path" />
        <button type="submit">Add Target</button>
      </form>
    </section>

    <section class="panel">
      <header class="panel-head">
        <h3>All Repositories</h3>
        <span class="chip"><span x-text="cards.length"></span> total</span>
      </header>

      <div class="repo-grid" x-show="cards.length">
        <template x-for="card in cards" :key="card.repo.id">
          <article class="repo-card">
            <header>
              <div>
                <h4><a :href="`/repositories/${card.repo.id}`" x-text="card.repo.name"></a></h4>
                <p x-text="card.repo.root_path"></p>
              </div>
              <span class="badge" x-text="card.health"></span>
            </header>
            <div class="repo-stats" x-show="card.metrics">
              <span><span x-text="card.metrics?.commits ?? 0"></span> commits</span>
              <span><span x-text="card.metrics?.pushes ?? 0"></span> pushes</span>
              <span><span x-text="card.metrics?.files_touched ?? 0"></span> files</span>
              <span><span x-text="card.metrics?.score ?? 0"></span> score</span>
            </div>
            <p class="muted" x-show="!card.metrics">No data yet.</p>
            <div class="sparkline">
              <template x-for="(bar, index) in card.sparkline" :key="`${card.repo.id}-${index}`">
                <span :style="`height:${Math.max(bar, 4)}px`"></span>
              </template>
            </div>
            <div class="button-row">
              <button type="button" @click="refreshRepo(card.repo.id)">Rescan</button>
              <button type="button" class="secondary" @click="toggleRepo(card.repo.id)">
                <span x-text="card.repo.is_monitored ? 'Disable' : 'Enable'"></span>
              </button>
              <button type="button" class="danger" @click="removeRepo(card.repo.id, card.repo.name)">Remove</button>
            </div>
          </article>
        </template>
      </div>
      <p class="muted" x-show="!cards.length">No repositories tracked yet. Add a path above to get started.</p>
    </section>
  </div>
</AppLayout>
