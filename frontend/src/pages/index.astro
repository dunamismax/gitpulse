---
import AppLayout from "../layouts/AppLayout.astro";
---

<AppLayout
  title="Dashboard"
  page="dashboard"
  activeNav="dashboard"
  eyebrow="Today"
  heading="What are you changing right now?"
  description="GitPulse keeps live work, committed work, and pushed work separate so the signal stays honest."
>
  <div class="page-body" x-data="window.gitpulse.dashboardPage()" x-init="init()">
    <div class="notice" x-cloak x-show="loading">Loading dashboard…</div>
    <div class="notice notice-error" x-cloak x-show="error" x-text="error"></div>

    <section class="grid six">
      <article class="stat-card"><span>Live Lines</span><strong x-text="summary.live_lines"></strong></article>
      <article class="stat-card"><span>Staged Lines</span><strong x-text="summary.staged_lines"></strong></article>
      <article class="stat-card"><span>Commits Today</span><strong x-text="summary.commits_today"></strong></article>
      <article class="stat-card"><span>Pushes Today</span><strong x-text="summary.pushes_today"></strong></article>
      <article class="stat-card"><span>Active Session</span><strong><span x-text="summary.active_session_minutes"></span> min</strong></article>
      <article class="stat-card"><span>Streak / Score</span><strong><span x-text="summary.streak_days"></span> / <span x-text="summary.today_score"></span></strong></article>
    </section>

    <section class="grid two">
      <article class="panel">
        <header class="panel-head">
          <h3>30 Day Trend</h3>
          <span class="chip">Changed lines + score</span>
        </header>
        <div class="trend-chart">
          <template x-for="point in trendPoints" :key="point.day">
            <div class="trend-bar" :style="barStyle(point.score)" :title="`${point.day}: score ${point.score}, ${point.changed_lines} lines`"></div>
          </template>
        </div>
      </article>

      <article class="panel">
        <header class="panel-head">
          <h3>12 Week Heatmap</h3>
          <span class="chip">Consistency</span>
        </header>
        <div class="heatmap">
          <template x-for="point in heatmapDays" :key="point.day">
            <div class="heat-cell" :class="heatmapClass(point.score)" :title="`${point.day}: score ${point.score}`"></div>
          </template>
        </div>
      </article>
    </section>

    <section class="grid two">
      <article class="panel">
        <header class="panel-head">
          <h3>Activity Feed</h3>
          <span class="chip">Live</span>
        </header>
        <div class="feed-list" x-show="activityFeed.length">
          <template x-for="item in activityFeed" :key="`${item.timestamp}-${item.kind}-${item.repo_name}`">
            <div class="feed-item">
              <strong x-text="item.repo_name"></strong>
              <span x-text="item.kind"></span>
              <small x-text="formatTime(item.timestamp)"></small>
            </div>
          </template>
        </div>
        <p class="muted" x-show="!activityFeed.length">No recent activity.</p>
      </article>

      <article class="panel">
        <header class="panel-head">
          <h3>Goals</h3>
          <span class="chip">Transparent scoring</span>
        </header>
        <div class="goal-stack" x-show="summary.goals.length">
          <template x-for="goal in summary.goals" :key="goal.label">
            <div class="goal-row">
              <div class="goal-meta">
                <span x-text="goal.label"></span>
                <strong><span x-text="goal.current"></span>/<span x-text="goal.target"></span></strong>
              </div>
              <div class="progress"><span :style="`width:${goal.percent}%`"></span></div>
            </div>
          </template>
        </div>
      </article>
    </section>

    <section class="panel">
      <header class="panel-head">
        <h3>Repository Pulse</h3>
        <span class="chip"><span x-text="repoCards.length"></span> tracked</span>
      </header>
      <div class="repo-grid" x-show="repoCards.length">
        <template x-for="card in repoCards" :key="card.repo.id">
          <article class="repo-card">
            <header>
              <div>
                <h4><a :href="`/repositories/${card.repo.id}`" x-text="card.repo.name"></a></h4>
                <p x-text="card.repo.root_path"></p>
              </div>
              <span class="badge" x-text="card.health"></span>
            </header>
            <div class="repo-stats" x-show="card.metrics">
              <span><span x-text="card.metrics?.commits ?? 0"></span> commits</span>
              <span><span x-text="card.metrics?.pushes ?? 0"></span> pushes</span>
              <span><span x-text="card.metrics?.files_touched ?? 0"></span> files</span>
              <span><span x-text="card.metrics?.score ?? 0"></span> score</span>
            </div>
            <p class="muted" x-show="!card.metrics">No data yet.</p>
            <div class="sparkline">
              <template x-for="(bar, index) in card.sparkline" :key="`${card.repo.id}-${index}`">
                <span :style="`height:${Math.max(bar, 4)}px`"></span>
              </template>
            </div>
            <div class="button-row">
              <button type="button" @click="refreshRepo(card.repo.id)">Rescan</button>
              <button type="button" class="secondary" @click="toggleRepo(card.repo.id)">
                <span x-text="card.repo.is_monitored ? 'Disable' : 'Enable'"></span>
              </button>
              <button type="button" class="danger" @click="removeRepo(card.repo.id, card.repo.name)">Remove</button>
            </div>
          </article>
        </template>
      </div>
      <p class="muted" x-show="!repoCards.length">No repositories tracked yet.</p>
    </section>
  </div>
</AppLayout>
