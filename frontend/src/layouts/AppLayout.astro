---
import "../styles/app.css";
import appScript from "../scripts/app.ts?url";

interface NavItem {
  href: string;
  key: string;
  label: string;
}

interface Props {
  title: string;
  page: string;
  activeNav: string;
  eyebrow: string;
  heading: string;
  description: string;
}

const { title, page, activeNav, eyebrow, heading, description } = Astro.props;
const hasActions = Astro.slots.has("actions");
const navItems: NavItem[] = [
  { href: "/", key: "dashboard", label: "Dashboard" },
  { href: "/repositories", key: "repositories", label: "Repositories" },
  { href: "/sessions", key: "sessions", label: "Sessions" },
  { href: "/achievements", key: "achievements", label: "Achievements" },
  { href: "/settings", key: "settings", label: "Settings" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · GitPulse</title>
  </head>
  <body data-page={page}>
    <div class="app-shell">
      <aside class="sidebar">
        <div class="brand">
          <div class="brand-mark">GP</div>
          <div>
            <h1>GitPulse</h1>
            <p>Local-first git analytics</p>
          </div>
        </div>
        <nav class="nav">
          {navItems.map((item) => (
            <a href={item.href} class:list={{ active: item.key === activeNav }}>{item.label}</a>
          ))}
        </nav>
      </aside>

      <main class="content">
        <section class:list={["page-head", hasActions && "spread"]}>
          <div>
            <p class="eyebrow">{eyebrow}</p>
            <h2>{heading}</h2>
            <p class="muted">{description}</p>
          </div>
          {hasActions && <div class="page-actions"><slot name="actions" /></div>}
        </section>
        <slot />
      </main>
    </div>

    <script type="module" src={appScript}></script>
  </body>
</html>
