---
import AchievementsPage from "../components/AchievementsPage.vue";
import AppLayout from "../layouts/AppLayout.astro";
import { apiBaseUrlFromEnv } from "../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
---

<AppLayout
  title="Achievements"
  activeNav="achievements"
  eyebrow="Achievements"
  heading="Consistency, not gimmicks"
  description="Score is separate from raw stats and the badge set stays intentionally grounded."
>
  <AchievementsPage client:load apiBaseUrl={apiBaseUrl} />
</AppLayout>
