---
import DashboardPage from "../components/DashboardPage.vue";
import AppLayout from "../layouts/AppLayout.astro";
import { apiBaseUrlFromEnv } from "../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
---

<AppLayout
  title="Dashboard"
  activeNav="dashboard"
  eyebrow="Today"
  heading="What are you changing right now?"
  description="GitPulse keeps live work, committed work, and pushed work separate so the signal stays honest."
>
  <DashboardPage client:load apiBaseUrl={apiBaseUrl} />
</AppLayout>
