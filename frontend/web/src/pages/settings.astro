---
import SettingsPage from "../components/SettingsPage.vue";
import AppLayout from "../layouts/AppLayout.astro";
import { apiBaseUrlFromEnv } from "../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
---

<AppLayout
  title="Settings"
  activeNav="settings"
  eyebrow="Settings"
  heading="Identity, goals, and boundaries"
  description="Configured author emails shape commit and push history totals. Live working-tree activity always counts locally."
>
  <SettingsPage client:load apiBaseUrl={apiBaseUrl} />
</AppLayout>
