---
import RepositoriesPage from "../../components/RepositoriesPage.vue";
import AppLayout from "../../layouts/AppLayout.astro";
import { apiBaseUrlFromEnv } from "../../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
---

<AppLayout
  title="Repositories"
  activeNav="repositories"
  eyebrow="Tracked Targets"
  heading="Repositories"
  description="Add a single repo or a parent folder. Nested repos are discovered and tracked individually."
>
  <RepositoriesPage client:load apiBaseUrl={apiBaseUrl} />
</AppLayout>
