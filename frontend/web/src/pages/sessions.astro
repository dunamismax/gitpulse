---
import SessionsPage from "../components/SessionsPage.vue";
import AppLayout from "../layouts/AppLayout.astro";
import { apiBaseUrlFromEnv } from "../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
---

<AppLayout
  title="Sessions"
  activeNav="sessions"
  eyebrow="Focus Sessions"
  heading="Session rhythm"
  description="Sessions are built from activity windows separated by inactivity gaps."
>
  <SessionsPage client:load apiBaseUrl={apiBaseUrl} />
</AppLayout>
