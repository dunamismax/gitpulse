---
import type { SessionSummary } from "@gitpulse/shared";
import { formatDateTime } from "@gitpulse/shared";

import BackendStatus from "../components/BackendStatus.astro";
import AppLayout from "../layouts/AppLayout.astro";
import {
  apiBaseUrlFromEnv,
  backendStatusFromError,
  createServerClient,
} from "../lib/server";

const apiBaseUrl = apiBaseUrlFromEnv(import.meta.env);
const client = createServerClient(apiBaseUrl);

let summary: SessionSummary | null = null;
let pageError: string | null = null;
let backendStatus = null;

try {
  summary = await client.sessions();
} catch (error) {
  pageError =
    error instanceof Error ? error.message : "Could not load sessions.";
  backendStatus = backendStatusFromError(error, apiBaseUrl);
}
---

<AppLayout
  title="Sessions"
  activeNav="sessions"
  eyebrow="Focus Sessions"
  heading="Session rhythm"
  description="Sessions are built from activity windows separated by inactivity gaps."
>
  {backendStatus && <BackendStatus status={backendStatus} />}
  {pageError && !backendStatus && (
    <section class="notice notice-error">
      <div>
        <strong>Sessions unavailable</strong>
        <p>{pageError}</p>
      </div>
    </section>
  )}

  {summary && (
    <>
      <section class="stats-grid three-up">
        <article class="stat-card"><span class="label">Total Minutes</span><strong>{summary.total_minutes}</strong></article>
        <article class="stat-card"><span class="label">Average Session</span><strong>{summary.average_length_minutes} min</strong></article>
        <article class="stat-card"><span class="label">Longest Session</span><strong>{summary.longest_session_minutes} min</strong></article>
      </section>

      <section class="panel">
        <div class="panel-head"><h3>Recent Sessions</h3></div>
        {
          summary.sessions.length ? (
            <div class="list-stack">
              {summary.sessions.map((session) => (
                <div class="list-row simple">
                  <div>
                    <strong>{session.active_minutes} min</strong>
                    <p>{formatDateTime(session.started_at)} to {formatDateTime(session.ended_at)}</p>
                  </div>
                  <span class="chip">{session.total_changed_lines} changed lines</span>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-guide compact-guide">
              <p class="empty-state">No sessions recorded yet. Sessions are derived data, so a fresh database stays blank until you import or rescan activity and then rebuild analytics.</p>
              <ol class="step-list">
                <li>Import recent history to backfill commit activity.</li>
                <li>Rescan active repositories to record current working-tree changes.</li>
                <li>Run rebuild analytics so GitPulse can derive session windows.</li>
              </ol>
            </div>
          )
        }
      </section>
    </>
  )}
</AppLayout>
